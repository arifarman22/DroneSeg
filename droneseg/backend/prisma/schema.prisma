datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

model Image {
  id               String      @id @default(uuid()) @db.Uuid
  originalFilename String
  storedFilename   String
  filePath         String
  width            Int?
  height           Int?
  sizeBytes        Int
  mimeType         String
  boundsMinLng     Float?      // west
  boundsMinLat     Float?      // south
  boundsMaxLng     Float?      // east
  boundsMaxLat     Float?      // north
  createdAt        DateTime    @default(now())

  detections       Detection[]

  @@index([createdAt])
  @@map("images")
}

model Detection {
  id                  String   @id @default(uuid()) @db.Uuid
  imageId             String   @db.Uuid
  modelUsed           String
  detectionsJson      Json
  maskPath            String?
  inferenceTimeMs     Int
  confidenceThreshold Float
  createdAt           DateTime @default(now())

  image               Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId])
  @@index([createdAt])
  @@map("detections")
}
